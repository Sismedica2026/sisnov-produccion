# ============================================================
# SEGUIMIENTO NOVEDADES OPERATIVAS - Variables de Entorno
# Copiar como .env para desarrollo local.
# En Render se configuran en Environment.
# ============================================================

DATABASE_URL=postgresql://usuario:password@host:5432/sisnov
NODE_ENV=production
PORT=3000

# Obligatorio en producción. Mínimo 32 caracteres aleatorios.
JWT_SECRET=genere_una_clave_larga_aleatoria_minimo_32_caracteres
JWT_EXPIRES_IN=8h

# Dominio público permitido. Ejemplo Render:
# ALLOWED_ORIGINS=https://sisnov-sismedica.onrender.com
ALLOWED_ORIGINS=

# Usuarios iniciales empresariales.
# Crea, sin borrar datos existentes: 2 admin, 1 gerente, 2 directores, 2 coordinadores y 20 supervisores.
# INITIAL_USERS_PASSWORD aplica solo a usuarios que todavía no existan.
INITIAL_USERS_PASSWORD=Cambie-Esta-Clave-2026!
ADMIN_PASSWORD=Cambie-Esta-Clave-2026!
MIN_PASSWORD_LENGTH=12

# Solo para desarrollo/pruebas. Nunca usar en producción.
SEED_DEMO_DATA=false

# Permite resetear la contraseña de los usuarios iniciales existentes durante el próximo deploy.
# Usar temporalmente en producción solo para recuperar acceso. Luego volver a false.
RESET_INITIAL_USERS_PASSWORD=false

# Token privado para integración Power BI/API gerencial.
# El endpoint /api/bi/kpis acepta x-api-key, x-bi-token, Authorization Bearer o query api_key.
BI_API_TOKEN=generar_token_largo_seguro
